
# Nomor admin (ganti dengan nomor Anda)
admin_number=6281234567890

# Batas jumlah grup sebelum dikirim ke admin
GROUP_THRESHOLD=5

# Jeda waktu minimum dan maksimum antar pesan (dalam milidetik)
DELAY_MIN=10000
DELAY_MAX=60000

# Konfigurasi pesan broadcast
MSG_TITLE="Judul Pesan"
MSG_BODY="Isi pesan"
MSG_THUMB="https://example.com/thumb.jpg"
MSG_MEDIA="https://example.com/video.mp4"
MSG_MEDIA_TYPE=1
MSG_SOURCE="https://example.com"

# Jadwal broadcast (gunakan format cron)
# Contoh: Setiap hari jam 8 pagi
# BROADCAST_SCHEDULE_1="0 8 * * *"
# BROADCAST_MESSAGE_FILE_1="messages/promo_vpn.txt"
